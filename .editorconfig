# top-most editorconfig
root = true

# All C# files
[*.cs]

# -----------------------------
# Indentation & spacing
# -----------------------------
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# -----------------------------
# Line length
# -----------------------------
max_line_length = 120

# -----------------------------
# Naming conventions
# -----------------------------
# PascalCase: classes, structs, interfaces, enums, methods, properties
dotnet_naming_rule.pascal_case_for_types_and_members.severity = warning
dotnet_naming_rule.pascal_case_for_types_and_members.symbols = types_and_members
dotnet_naming_rule.pascal_case_for_types_and_members.style = pascal_case_style

dotnet_naming_symbols.types_and_members.applicable_kinds = class, struct, interface, enum, property, method
dotnet_naming_symbols.types_and_members.applicable_accessibilities = *
dotnet_naming_symbols.types_and_members.required_modifiers = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# camelCase: local variables and method parameters
dotnet_naming_rule.camel_case_for_locals.severity = warning
dotnet_naming_rule.camel_case_for_locals.symbols = locals_and_parameters
dotnet_naming_rule.camel_case_for_locals.style = camel_case_style

dotnet_naming_symbols.locals_and_parameters.applicable_kinds = parameter, local
dotnet_naming_style.camel_case_style.capitalization = camel_case

# _camelCase: private fields (Unity)
dotnet_naming_rule.underscore_camel_case_private.severity = warning
dotnet_naming_rule.underscore_camel_case_private.symbols = private_fields
dotnet_naming_rule.underscore_camel_case_private.style = underscore_camel_case_style

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case_style.capitalization = camel_case
dotnet_naming_style.underscore_camel_case_style.required_prefix = _

# UPPER_SNAKE_CASE: constants
dotnet_naming_rule.upper_snake_case_constants.severity = warning
dotnet_naming_rule.upper_snake_case_constants.symbols = constants
dotnet_naming_rule.upper_snake_case_constants.style = upper_snake_case_style

dotnet_naming_symbols.constants.applicable_kinds = field
dotnet_naming_symbols.constants.required_modifiers = const, static
dotnet_naming_style.upper_snake_case_style.capitalization = all_upper
dotnet_naming_style.upper_snake_case_style.word_separator = _

# -----------------------------
# Using directives
# -----------------------------
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
file_header_template = unset

# -----------------------------
# Braces & spacing
# -----------------------------
csharp_new_line_before_open_brace = all
csharp_space_after_cast = true
csharp_space_before_colon_in_inheritance_clause = true
csharp_preserve_single_line_blocks = false

# -----------------------------
# File encoding
# -----------------------------
charset = utf-8